# FastAPI configuration
APP_NAME=personal-ai
DEBUG=false

# Ollama configuration
# For Docker: use http://ollama:11434
# For local: use http://127.0.0.1:11434
OLLAMA_BASE_URL=http://ollama:11434
OLLAMA_CHAT_MODEL=llama3:8b
OLLAMA_EMBED_MODEL=nomic-embed-text
OLLAMA_TIMEOUT=120.0

# Pluggable LLM routing (provider adapters + per-stage model selection)
LLM_DEFAULT_PROVIDER=ollama
LLM_DEFAULT_MODEL=llama3:8b
# Optional OpenAI-compatible provider (LM Studio, vLLM, hosted gateways, etc.)
LLM_OPENAI_BASE_URL=
LLM_OPENAI_API_KEY=
LLM_OPENAI_TIMEOUT=60.0
LLM_PLANNER_PROVIDER=ollama
LLM_PLANNER_MODEL=qwen2.5:3b
LLM_SYNTHESIZER_PROVIDER=ollama
LLM_SYNTHESIZER_MODEL=qwen2.5:7b
LLM_REVIEWER_PROVIDER=ollama
LLM_REVIEWER_MODEL=qwen2.5:3b
LLM_WRITER_PROVIDER=ollama
LLM_WRITER_MODEL=llama3:8b

# Qdrant configuration
# For Docker: use http://qdrant:6333
# For local: use http://127.0.0.1:6333
QDRANT_URL=http://qdrant:6333
QDRANT_API_KEY=
QDRANT_COLLECTION=personal_ai_documents
QDRANT_DISTANCE=Cosine
EMBEDDING_DIMENSION=768
DEFAULT_TOP_K=4

# UI CORS origins (comma separated)
CORS_ORIGINS=http://localhost:5173,http://127.0.0.1:5173,http://localhost:8000,http://127.0.0.1:8000

# Adapter cache configuration
ENABLE_ADAPTER_CACHE=true
ADAPTER_CACHE_BACKEND=redis
ADAPTER_CACHE_DEFAULT_TTL_SECONDS=60
REDIS_URL=redis://redis:6379/0

# Observability defaults
GRAFANA_ADMIN_PASSWORD=admin

# Optional framework toggles
ENABLE_LANGCHAIN_AGENT=false
ENABLE_LLAMAINDEX_RAG=false

# Workflow orchestration memory
WORKFLOW_MEMORY_PATH=memory/workflow_sessions.json
WORKFLOW_MEMORY_MAX_ENTRIES=24
