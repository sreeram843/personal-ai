# Cloud inference configuration — copy to .env.cloud and fill in your values.
# Usage: docker compose -f docker-compose.yml -f docker-compose.cloud.yml --env-file .env.cloud up
#
# NEVER commit the filled-in version of this file.

# ─────────────────────────────────────────────────────────────────────────────
# Provider selection — uncomment ONE block
# ─────────────────────────────────────────────────────────────────────────────

# ── GMI Cloud ─────────────────────────────────────────────────────────────────
# Free: meta-llama/Llama-3.1-8B-Instruct ($0/1M tokens)
# Paid: Qwen/Qwen2.5-7B-Instruct, Qwen/Qwen2.5-3B-Instruct (~$0.10/1M tokens)
# Get key: https://console.gmicloud.ai → Settings → API Keys
#
LLM_CLOUD_BASE_URL=https://api.gmi-serving.com
LLM_CLOUD_API_KEY=your-gmi-api-key-here
LLM_CLOUD_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_CLOUD_PLANNER_MODEL=Qwen/Qwen2.5-3B-Instruct
LLM_CLOUD_SYNTHESIZER_MODEL=Qwen/Qwen2.5-7B-Instruct
LLM_CLOUD_REVIEWER_MODEL=Qwen/Qwen2.5-3B-Instruct
LLM_CLOUD_WRITER_MODEL=meta-llama/Llama-3.1-8B-Instruct
LLM_CLOUD_TIMEOUT=60.0

# ── Groq (very fast inference, generous free tier) ────────────────────────────
# Models: llama-3.1-8b-instant, llama3-8b-8192, qwen-qwq-32b, gemma2-9b-it
# Get key: https://console.groq.com → API Keys
#
# LLM_CLOUD_BASE_URL=https://api.groq.com/openai
# LLM_CLOUD_API_KEY=your-groq-api-key-here
# LLM_CLOUD_DEFAULT_MODEL=llama-3.1-8b-instant
# LLM_CLOUD_PLANNER_MODEL=llama-3.1-8b-instant
# LLM_CLOUD_SYNTHESIZER_MODEL=llama-3.1-8b-instant
# LLM_CLOUD_REVIEWER_MODEL=llama-3.1-8b-instant
# LLM_CLOUD_WRITER_MODEL=llama-3.1-8b-instant
# LLM_CLOUD_TIMEOUT=30.0

# ── Together AI ($25 free credit on signup) ───────────────────────────────────
# Models: meta-llama/Llama-3.1-8B-Instruct-Turbo, Qwen/Qwen2.5-7B-Instruct-Turbo
# Get key: https://api.together.ai → Settings → API Keys
#
# LLM_CLOUD_BASE_URL=https://api.together.xyz
# LLM_CLOUD_API_KEY=your-together-api-key-here
# LLM_CLOUD_DEFAULT_MODEL=meta-llama/Llama-3.1-8B-Instruct-Turbo
# LLM_CLOUD_PLANNER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
# LLM_CLOUD_SYNTHESIZER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
# LLM_CLOUD_REVIEWER_MODEL=Qwen/Qwen2.5-7B-Instruct-Turbo
# LLM_CLOUD_WRITER_MODEL=meta-llama/Llama-3.1-8B-Instruct-Turbo
# LLM_CLOUD_TIMEOUT=60.0

# ── Fireworks AI ──────────────────────────────────────────────────────────────
# Models: accounts/fireworks/models/llama-v3p1-8b-instruct
# Get key: https://fireworks.ai/account/api-keys
#
# LLM_CLOUD_BASE_URL=https://api.fireworks.ai/inference
# LLM_CLOUD_API_KEY=your-fireworks-api-key-here
# LLM_CLOUD_DEFAULT_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
# LLM_CLOUD_PLANNER_MODEL=accounts/fireworks/models/qwen2p5-7b-instruct
# LLM_CLOUD_SYNTHESIZER_MODEL=accounts/fireworks/models/qwen2p5-7b-instruct
# LLM_CLOUD_REVIEWER_MODEL=accounts/fireworks/models/qwen2p5-7b-instruct
# LLM_CLOUD_WRITER_MODEL=accounts/fireworks/models/llama-v3p1-8b-instruct
# LLM_CLOUD_TIMEOUT=60.0
